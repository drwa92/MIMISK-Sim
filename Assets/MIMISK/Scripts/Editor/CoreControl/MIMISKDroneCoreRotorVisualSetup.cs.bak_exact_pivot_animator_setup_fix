using UnityEditor;
using UnityEditor.SceneManagement;
using UnityEngine;

public static class MIMISKDroneCoreRotorVisualSetup
{
    [MenuItem("MIMISK/Drone/Core Control/Setup Core Rotor Visual Animation")]
    public static void SetupRotorVisualAnimation()
    {
        GameObject drone = Selection.activeGameObject;

        if (drone == null || drone.GetComponent<Rigidbody>() == null)
        {
            drone = GameObject.Find("Drone");
        }

        if (drone == null)
        {
            Debug.LogError("[MIMISK] Could not find Drone root.");
            return;
        }

        MIMISKDroneCoreRotorController core =
            drone.GetComponent<MIMISKDroneCoreRotorController>();

        if (core == null)
        {
            Debug.LogError("[MIMISK] Core Rotor Controller missing. Run Core Control setup first.");
            return;
        }

        MIMISKDroneCoreRotorVisualAnimator anim =
            drone.GetComponent<MIMISKDroneCoreRotorVisualAnimator>();

        if (anim == null)
        {
            anim = drone.AddComponent<MIMISKDroneCoreRotorVisualAnimator>();
        }

        anim.coreController = core;
        anim.animateRotors = true;
        anim.localSpinAxis = Vector3.up;
        anim.idleRpm = 900.0f;
        anim.maxRpm = 6500.0f;
        anim.rpmResponseHz = 14.0f;

        anim.AutoFindPropellerTransforms();

        EditorUtility.SetDirty(anim);
        EditorSceneManager.MarkSceneDirty(EditorSceneManager.GetActiveScene());
        AssetDatabase.SaveAssets();

        Debug.Log("[MIMISK] Core rotor visual animation configured. If a rotor field is empty, assign the propeller mesh manually.");
    }
}
