        BuildDashboard();
    }

    private Font ResolveRuntimeFont()
    {
        Font font = null;

        try
        {
            font = Resources.GetBuiltinResource<Font>("LegacyRuntime.ttf");
        }
        catch
        {
            font = null;
        }

        if (font != null)
        {
            return font;
        }

        try
        {
            font = Font.CreateDynamicFontFromOSFont("Arial", 14);
        }
        catch
        {
            font = null;
        }

        if (font != null)
        {
            return font;
        }

        try
        {
            font = Font.CreateDynamicFontFromOSFont("Liberation Sans", 14);
        }
        catch
        {
            font = null;
        }

        return font;
    }

