    private string BuildAlerts(float slack, float stretch, float tension, bool droneMotionAllowed, bool safeToDeploy, bool smartActive)
    {
        string s = "";

        if (!droneMotionAllowed)
        {
            s += "● Drone motion blocked: ROV/tether deployed\n";
        }

        if (safeToDeploy)
        {
            s += "● Safe to deploy ROV\n";
        }

        if (smartActive)
        {
            s += "● Smart TMS active\n";
        }

        if (!float.IsNaN(stretch) && stretch > 0.03f)
        {
            s += "⚠ Tether stretch high: " + stretch.ToString("F3") + " m\n";
        }

        if (!float.IsNaN(slack) && slack > 0.50f)
        {
            s += "⚠ Tether slack high: " + slack.ToString("F2") + " m\n";
        }

        if (!float.IsNaN(tension) && tension > 10.0f)
        {
            s += "⚠ Tether tension proxy high: " + tension.ToString("F1") + " N\n";
        }

        if (s.Length == 0)
        {
            s = "● No active alerts\n";
        }

        return s;
    }

    private float ComputeRovDepth()
    {
        float waterY = ReadFloat(unifiedTether, "waterSurfaceY", 0.0f);
        Transform t = ReadTransform(unifiedTether, "miniRovRoot");

        if (t != null)
        {
            return Mathf.Max(0.0f, waterY - t.position.y);
        }

        Rigidbody rb = ReadRigidbody(unifiedTether, "miniRovRigidbody");

        if (rb != null)
        {
            return Mathf.Max(0.0f, waterY - rb.position.y);
        }

        return float.NaN;
    }

    private void OnDroneLandSurface()
    {
        SwitchDashboardCameraPair(droneFollowCamera, dronePayloadCamera, "Drone Follow", "DroneCamera");

        if (!CallFirst(droneAgent, "AgentLandOnSurface", "AgentSurfaceHold"))
        {
            CallFirst(droneFlightManager, "StartLandingOnSurface", "EnterSurfaceHold");
        }
    }

    private void OnDroneTakeoff()
    {
        SwitchDashboardCameraPair(droneFollowCamera, dronePayloadCamera, "Drone Follow", "DroneCamera");

        if (!CallFirst(droneAgent, "AgentTakeoff"))
        {
            CallFirst(droneFlightManager, "StartTakeoff");
        }
