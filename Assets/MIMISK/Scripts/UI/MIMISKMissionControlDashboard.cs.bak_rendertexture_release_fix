    private void Update()
    {
        if (!dashboardEnabled)
        {
            if (canvas != null)
            {
                canvas.enabled = false;
            }

            return;
        }

        if (canvas != null)
        {
            canvas.enabled = true;
        }

        if (autoFindPeriodically)
        {
            autoFindTimerS += Time.unscaledDeltaTime;

            if (autoFindTimerS >= autoFindPeriodS)
            {
                autoFindTimerS = 0.0f;
                AutoFindReferences();
            }
        }

        UpdateDashboardText();
    }

