    private bool SwitchDashboardCameraPair(
        Camera mainCamera,
        Camera previewCamera,
        string mainViewName,
        string previewViewName)
    {
        bool switched =
            SwitchDashboardCamera(mainCamera, mainViewName);

        if (switched)
        {
            activePreviewCamera =
                previewCamera != null
                    ? previewCamera
                    : mainCamera;

            currentCameraView =
                mainViewName + " / Preview: " + previewViewName;

            UpdateCameraPreview();
        }

        return switched;
    }

    private bool SwitchDashboardCamera(Camera selectedCamera, string viewName)
    {
        if (!switchUnityMainCamera)
        {
            return false;
        }

        AutoFindReferences();

        if (selectedCamera == null)
        {
            return false;
        }

        Camera[] knownCameras =
        {
            droneFollowCamera,
            dronePayloadCamera,
            rovFollowCamera,
            rovFrontCamera
        };

        for (int i = 0; i < knownCameras.Length; i++)
        {
            Camera c =
                knownCameras[i];

            if (c == null)
            {
                continue;
            }

            c.gameObject.SetActive(true);
            c.enabled = false;
        }

        selectedCamera.gameObject.SetActive(true);
        selectedCamera.enabled = true;
        selectedCamera.targetDisplay = 0;
        selectedCamera.depth = 20.0f;

        currentCameraView =
            viewName;

        if (manageAudioListeners)
        {
            AudioListener[] listeners =
                Resources.FindObjectsOfTypeAll<AudioListener>();

            for (int i = 0; i < listeners.Length; i++)
            {
                AudioListener l =
                    listeners[i];

                if (l == null ||
                    l.gameObject == null ||
                    !l.gameObject.scene.IsValid())
                {
                    continue;
                }

                l.enabled =
                    l.gameObject == selectedCamera.gameObject;
            }

            AudioListener selectedListener =
                selectedCamera.GetComponent<AudioListener>();

            if (selectedListener == null)
            {
                selectedListener =
                    selectedCamera.gameObject.AddComponent<AudioListener>();
            }

            selectedListener.enabled =
                true;
        }

        return true;
    }

    private Camera FindCameraByName(string objectName)
    {
        if (string.IsNullOrEmpty(objectName))
        {
            return null;
        }

        Camera[] cameras =
            Resources.FindObjectsOfTypeAll<Camera>();

        for (int i = 0; i < cameras.Length; i++)
        {
            Camera c =
                cameras[i];

            if (c == null ||
                c.gameObject == null ||
                !c.gameObject.scene.IsValid())
            {
                continue;
            }

            if (c.gameObject.name == objectName)
            {
                return c;
            }
        }

        return null;
    }

    private void UpdateCameraPreview()
    {
        if (!enableCameraPreviewPanel)
        {
            if (cameraPreviewImage != null)
            {
                cameraPreviewImage.enabled = false;
            }

            return;
        }

        if (cameraPreviewImage == null)
        {
            return;
        }

        Camera source =
            activePreviewCamera;

        if (source == null)
        {
            if (currentCameraView != null &&
                currentCameraView.Contains("ROV"))
            {
                source =
                    rovFrontCamera != null
                        ? rovFrontCamera
                        : rovFollowCamera;
            }
            else
            {
                source =
                    dronePayloadCamera != null
                        ? dronePayloadCamera
                        : droneFollowCamera;
            }
        }

        if (source == null)
        {
            return;
        }

        EnsurePreviewCameraAndTexture();

        if (dashboardPreviewCamera == null ||
            dashboardPreviewTexture == null)
        {
            return;
        }

        CopyCameraForPreview(source, dashboardPreviewCamera);

        dashboardPreviewCamera.targetTexture =
            dashboardPreviewTexture;

        dashboardPreviewCamera.enabled =
            true;

        cameraPreviewImage.enabled =
            true;

        cameraPreviewImage.texture =
            dashboardPreviewTexture;
    }

    private void EnsurePreviewCameraAndTexture()
    {
        int w =
            Mathf.Max(128, previewTextureWidth);

        int h =
            Mathf.Max(72, previewTextureHeight);

        if (dashboardPreviewTexture == null ||
            dashboardPreviewTexture.width != w ||
            dashboardPreviewTexture.height != h)
        {
            if (dashboardPreviewTexture != null)
            {
                dashboardPreviewTexture.Release();
            }

            dashboardPreviewTexture =
                new RenderTexture(
                    w,
                    h,
                    16,
                    RenderTextureFormat.ARGB32
                );

            dashboardPreviewTexture.name =
                "MIMISK_DashboardCameraPreview_RT";

            dashboardPreviewTexture.Create();
        }

        if (dashboardPreviewCamera == null)
        {
            GameObject go =
                GameObject.Find("MIMISK_DashboardPreviewCamera");

            if (go == null)
            {
                go =
                    new GameObject("MIMISK_DashboardPreviewCamera");

                go.hideFlags =
                    HideFlags.DontSave;
            }

            dashboardPreviewCamera =
                go.GetComponent<Camera>();

            if (dashboardPreviewCamera == null)
            {
                dashboardPreviewCamera =
                    go.AddComponent<Camera>();
            }

            AudioListener listener =
                go.GetComponent<AudioListener>();

            if (listener != null)
            {
                listener.enabled =
                    false;
            }
        }
    }

    private void CopyCameraForPreview(Camera source, Camera preview)
    {
        if (source == null || preview == null)
        {
            return;
        }

        preview.transform.position =
            source.transform.position;

        preview.transform.rotation =
            source.transform.rotation;

        preview.clearFlags =
            source.clearFlags;

        preview.backgroundColor =
            source.backgroundColor;

        preview.cullingMask =
            source.cullingMask;

        preview.orthographic =
            source.orthographic;

        preview.orthographicSize =
            source.orthographicSize;

        preview.fieldOfView =
            source.fieldOfView;

        preview.nearClipPlane =
            source.nearClipPlane;

        preview.farClipPlane =
            source.farClipPlane;

        preview.allowHDR =
            source.allowHDR;

        preview.allowMSAA =
            source.allowMSAA;

        preview.depth =
            -100.0f;

        preview.targetDisplay =
            0;
    }

    private MonoBehaviour FindBehaviourByTypeName(string typeName)
    {
        MonoBehaviour[] behaviours = Resources.FindObjectsOfTypeAll<MonoBehaviour>();

        for (int i = 0; i < behaviours.Length; i++)
        {
            MonoBehaviour b = behaviours[i];

            if (b == null || b.gameObject == null || !b.gameObject.scene.IsValid())
            {
