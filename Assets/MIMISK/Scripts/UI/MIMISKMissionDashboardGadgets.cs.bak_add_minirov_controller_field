    private void PopulateDropdowns()
    {
        AutoFindReferences();

        PopulateDropdownFromEnumField(droneTrajectoryDropdown, droneTrajectoryPlanner, "trajectoryType");
        PopulateDropdownFromEnumField(miniRovPathDropdown, miniRovPathPlanner, "selectedPathType");

        selectedDroneTrajectory =
            droneTrajectoryDropdown != null && droneTrajectoryDropdown.options.Count > 0
                ? droneTrajectoryDropdown.options[droneTrajectoryDropdown.value].text
                : CurrentEnumName(droneTrajectoryPlanner, "trajectoryType");

        selectedMiniRovPath =
            miniRovPathDropdown != null && miniRovPathDropdown.options.Count > 0
                ? miniRovPathDropdown.options[miniRovPathDropdown.value].text
                : CurrentEnumName(miniRovPathPlanner, "selectedPathType");
    }

    private void UpdateGauges()
    {
        if (gauges.Count == 0)
        {
            return;
        }

        float deployed = ReadFloat(lowLevelTether, "deployedLengthM", 0.0f);
        float target = ReadFloat(lowLevelTether, "targetLengthM", 0.0f);
        float maxLen = Mathf.Max(0.01f, ReadFloat(lowLevelTether, "maximumLengthM", 12.0f));
        float slack = ReadFloat(lowLevelTether, "slackM", 0.0f);
        float stretch = ReadFloat(lowLevelTether, "stretchM", 0.0f);
        float winchRate = ReadFloat(lowLevelTether, "winchCommandRateMS", 0.0f);

        SetGauge("Deployed", deployed / maxLen, deployed.ToString("F2") + " m", green);
        SetGauge("Target", target / maxLen, target.ToString("F2") + " m", blue);

        Color slackColor = slack > 0.60f ? red : (slack > 0.25f ? yellow : green);
        SetGauge("Slack", Mathf.Clamp01(slack / 0.80f), slack.ToString("F2") + " m", slackColor);

        Color stretchColor = stretch > 0.03f ? red : (stretch > 0.01f ? yellow : green);
        SetGauge("Stretch", Mathf.Clamp01(stretch / 0.08f), stretch.ToString("F3") + " m", stretchColor);

        float maxRate = Mathf.Max(
            0.01f,
            Mathf.Max(
                ReadFloat(lowLevelTether, "payoutSpeedMS", 0.25f),
                ReadFloat(lowLevelTether, "recoverySpeedMS", 0.30f)
            )
        );

        Color winchColor = Mathf.Abs(winchRate) > 0.01f ? blue : muted;
        SetGauge("Winch", Mathf.Clamp01(Mathf.Abs(winchRate) / maxRate), winchRate.ToString("F2") + " m/s", winchColor);
    }

    private void UpdatePhaseTimeline()
    {
        if (phaseNodes.Count == 0)
        {
            return;
        }

        string droneFlight = ReadString(droneFlightManager, "flightMode", "missing");
        string droneMission = ReadString(droneMissionManager, "missionState", "missing");
        string tetherState = ReadString(unifiedTether, "tetherState", "missing");
        string rovMission = ReadString(miniRovMissionManager, "missionState", "missing");

        bool surface =
            droneFlight.Contains("Surface") ||
            droneMission.Contains("ReadyForTether");

        bool deploy =
            tetherState.Contains("Deploying") ||
            tetherState.Contains("DynamicStabilizing") ||
            tetherState.Contains("ReadyForRovControl") ||
            tetherState.Contains("RovControlActive");

        bool rovControl =
            tetherState.Contains("RovControlActive") ||
            rovMission.Contains("StationHolding") ||
            rovMission.Contains("ExecutingMission");

        bool mission =
            rovMission.Contains("ExecutingMission") ||
            rovMission.Contains("Dwelling") ||
            rovMission.Contains("StopAndLook");

        bool returning =
            rovMission.Contains("ReturningHome") ||
            rovMission.Contains("RecoveryReady");

        bool recover =
            tetherState.Contains("Recovering") ||
            tetherState.Contains("Recovered");

        SetPhase("Surface", surface, surface && !deploy);
        SetPhase("Deploy", deploy, tetherState.Contains("Deploying") || tetherState.Contains("DynamicStabilizing"));
        SetPhase("ROV Ctrl", rovControl, tetherState.Contains("RovControlActive") && !mission);
        SetPhase("Mission", mission, mission);
        SetPhase("Return", returning, rovMission.Contains("ReturningHome"));
        SetPhase("Recover", recover, tetherState.Contains("Recovering"));

        phaseSummary =
            "Drone=" + droneFlight +
            "; Tether=" + tetherState +
            "; ROV=" + rovMission;
    }

    private void UpdateTopDownMap()
    {
        if (trajectoryMap != null)
        {
            trajectoryMap.SetReferences(
                droneRoot,
                miniRovRoot,
                lowLevelTether,
                miniRovController
            );

            return;
        }

        // Legacy camera-map fallback is intentionally disabled.
        // The dashboard now uses the vector trajectory map instead of a camera view.
    }

    private void UpdateSelectorStatus()
    {
        if (selectorStatusText == null)
        {
            return;
        }

        selectorStatusText.text =
            "Drone: " + CurrentEnumName(droneTrajectoryPlanner, "trajectoryType") + "\n" +
            "MiniROV: " + CurrentEnumName(miniRovPathPlanner, "selectedPathType") + "\n" +
            "Last: " + lastUiEvent;
    }

    private void ApplyDroneTrajectorySelection()
    {
        AutoFindReferences();

        if (droneTrajectoryDropdown == null)
        {
            return;
        }

        string value =
            droneTrajectoryDropdown.options[droneTrajectoryDropdown.value].text;

        bool okPlanner =
            SetEnumFieldOrProperty(droneTrajectoryPlanner, "trajectoryType", value);

        // Mission manager uses the same trajectory enum type for survey/transit/deployment fields.
        // We set surveyTrajectory because the UI is a user-selected mission/pattern choice.
        SetEnumFieldOrProperty(droneMissionManager, "surveyTrajectory", value);

        selectedDroneTrajectory = value;
        lastUiEvent = okPlanner ? "applied_drone_trajectory_" + value : "failed_apply_drone_trajectory";
    }

    private void StartDroneSelectedMission()
    {
        ApplyDroneTrajectorySelection();

        if (!CallFirst(droneAgent, "AgentStartDroneMission", "AgentStartSelectedMission"))
        {
            if (!CallFirst(droneMissionManager, "StartMission"))
            {
                lastUiEvent = "failed_start_drone_mission";
                return;
            }
        }

        lastUiEvent = "started_drone_mission_" + selectedDroneTrajectory;
    }

    private void ApplyMiniRovPathSelection()
    {
        AutoFindReferences();

        if (miniRovPathDropdown == null)
        {
            return;
        }

        string value =
            miniRovPathDropdown.options[miniRovPathDropdown.value].text;

        bool okPlanner =
            SetEnumFieldOrProperty(miniRovPathPlanner, "selectedPathType", value);

        SetBoolFieldOrProperty(miniRovMissionManager, "usePathPlannerSelectedPath", true);

        selectedMiniRovPath = value;
        lastUiEvent = okPlanner ? "applied_minirov_path_" + value : "failed_apply_minirov_path";
    }

    private void StartMiniRovSelectedMission()
    {
        ApplyMiniRovPathSelection();

        if (!CallFirst(miniRovAgent, "AgentStartSelectedMission", "AgentStartCurrentPath", "AgentStartMission"))
        {
            if (!CallFirst(miniRovMissionManager, "StartSelectedMission", "StartMission"))
            {
                lastUiEvent = "failed_start_minirov_mission";
                return;
            }
        }

        lastUiEvent = "started_minirov_path_" + selectedMiniRovPath;
    }

    private void SetGauge(string name, float fraction, string value, Color fillColor)
    {
        Gauge g = gauges.Find(x => x.name == name);

        if (g == null || g.fill == null)
        {
            return;
        }

        RectTransform rt = g.fill.GetComponent<RectTransform>();
        float maxWidth = 190.0f;
        rt.sizeDelta = new Vector2(Mathf.Clamp01(fraction) * maxWidth, rt.sizeDelta.y);

        g.fill.color = fillColor;

        if (g.value != null)
        {
            g.value.text = value;
        }
    }

    private void SetPhase(string name, bool completedOrAvailable, bool active)
    {
        PhaseNode node = phaseNodes.Find(x => x.name == name);

        if (node == null || node.dot == null)
        {
            return;
        }

        if (active)
        {
            node.dot.color = yellow;
        }
        else if (completedOrAvailable)
        {
            node.dot.color = green;
        }
        else
        {
            node.dot.color = muted;
        }
    }

    private void ReleaseTopDownTextureSafely()
    {
        if (topDownCamera != null &&
            topDownCamera.targetTexture == topDownTexture)
        {
            topDownCamera.targetTexture = null;
        }

        if (topDownRawImage != null &&
            topDownRawImage.texture == topDownTexture)
        {
            topDownRawImage.texture = null;
        }

        if (topDownTexture != null)
        {
            topDownTexture.Release();
            topDownTexture = null;
        }
    }

    private void EnsureTopDownCamera()
    {
        if (!enableTopDownMap)
        {
            return;
        }

        if (topDownTexture == null ||
            topDownTexture.width != mapTextureWidth ||
            topDownTexture.height != mapTextureHeight)
        {
            ReleaseTopDownTextureSafely();

            topDownTexture =
                new RenderTexture(
                    Mathf.Max(128, mapTextureWidth),
                    Mathf.Max(128, mapTextureHeight),
                    16,
                    RenderTextureFormat.ARGB32
                );

            topDownTexture.name =
                "MIMISK_TopDownMap_RT";

            topDownTexture.Create();
        }

        if (topDownCamera == null)
        {
            GameObject go = GameObject.Find("MIMISK_TopDownMapCamera");

            if (go == null)
            {
                go = new GameObject("MIMISK_TopDownMapCamera");
                go.hideFlags = HideFlags.DontSave;
            }

            topDownCamera = go.GetComponent<Camera>();

            if (topDownCamera == null)
            {
                topDownCamera = go.AddComponent<Camera>();
            }

            AudioListener listener = go.GetComponent<AudioListener>();

            if (listener != null)
            {
                listener.enabled = false;
            }
        }

        topDownCamera.clearFlags = CameraClearFlags.SolidColor;
        topDownCamera.backgroundColor = new Color(0.0f, 0.05f, 0.07f, 1.0f);
        topDownCamera.orthographic = true;
        topDownCamera.targetDisplay = 0;
        topDownCamera.depth = -80.0f;
        topDownCamera.targetTexture = topDownTexture;
    }

    private void PopulateDropdownFromEnumField(Dropdown dropdown, object target, string memberName)
    {
        if (dropdown == null)
        {
            return;
        }

        string[] names =
            GetEnumNamesOrFallback(target, memberName);

        dropdown.ClearOptions();

        if (names == null || names.Length == 0)
        {
            dropdown.AddOptions(new List<string> { "missing" });
            dropdown.value = 0;
            dropdown.RefreshShownValue();
            return;
        }

        dropdown.AddOptions(new List<string>(names));

        string current =
            CurrentEnumName(target, memberName);

        int index =
            Array.IndexOf(names, current);

        if (index < 0)
        {
            index = 0;
        }

        dropdown.value =
            index;

        dropdown.RefreshShownValue();
    }

    private string[] GetEnumNamesOrFallback(object target, string memberName)
    {
        Type enumType =
            GetMemberType(target, memberName);

        if (enumType != null && enumType.IsEnum)
        {
            return Enum.GetNames(enumType);
        }

        if (memberName == "trajectoryType")
        {
            return new string[]
            {
                "Circle",
                "SpiralOut",
                "HelixDown",
                "HelixUpDown",
                "FigureEight",
                "SmoothSquare",
                "Lawnmower",
                "DeploymentApproach"
            };
        }

        if (memberName == "selectedPathType")
        {
            return new string[]
            {
                "StationHold",
                "GoToPoint",
                "LineOutAndBack",
                "Square",
                "RectangleSurvey",
                "LawnmowerSurvey",
                "CircleInspection",
                "StopAndLookInspection",
                "SpiralSearch",
                "HelixInspection",
                "FigureEight",
                "ReturnHome"
            };
        }

        return new string[0];
    }

    private bool SetEnumFieldOrProperty(object target, string memberName, string enumName)
    {
        if (target == null || string.IsNullOrEmpty(enumName))
        {
            return false;
        }

        Type type = target.GetType();

        FieldInfo field =
            type.GetField(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (field != null && field.FieldType.IsEnum)
        {
            object enumValue = Enum.Parse(field.FieldType, enumName);
            field.SetValue(target, enumValue);
            return true;
        }

        PropertyInfo prop =
            type.GetProperty(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (prop != null && prop.CanWrite && prop.PropertyType.IsEnum)
        {
            object enumValue = Enum.Parse(prop.PropertyType, enumName);
            prop.SetValue(target, enumValue, null);
            return true;
        }

        return false;
    }

    private bool SetBoolFieldOrProperty(object target, string memberName, bool value)
    {
        if (target == null)
        {
            return false;
        }

        Type type = target.GetType();

        FieldInfo field =
            type.GetField(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (field != null && field.FieldType == typeof(bool))
        {
            field.SetValue(target, value);
            return true;
        }

        PropertyInfo prop =
            type.GetProperty(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (prop != null && prop.CanWrite && prop.PropertyType == typeof(bool))
        {
            prop.SetValue(target, value, null);
            return true;
        }

        return false;
    }

    private string CurrentEnumName(object target, string memberName)
    {
        object value = GetMember(target, memberName);
        return value != null ? value.ToString() : "missing";
    }

    private Type GetMemberType(object target, string memberName)
    {
        if (target == null)
        {
            return null;
        }

        Type type = target.GetType();

        FieldInfo field =
            type.GetField(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (field != null)
        {
            return field.FieldType;
        }

        PropertyInfo prop =
            type.GetProperty(memberName, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (prop != null)
        {
            return prop.PropertyType;
        }

        return null;
    }

    private bool CallFirst(object target, params string[] methodNames)
    {
        if (target == null)
        {
            return false;
        }

        Type type = target.GetType();

        for (int i = 0; i < methodNames.Length; i++)
        {
            MethodInfo method =
                type.GetMethod(
                    methodNames[i],
                    BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic
                );

            if (method != null && method.GetParameters().Length == 0)
            {
                method.Invoke(target, null);
                return true;
            }
        }

        return false;
    }

    private object GetMember(object target, string name)
    {
        if (target == null || string.IsNullOrEmpty(name))
        {
            return null;
        }

        Type type = target.GetType();

        FieldInfo field =
            type.GetField(name, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (field != null)
        {
            return field.GetValue(target);
        }

        PropertyInfo prop =
            type.GetProperty(name, BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);

        if (prop != null && prop.CanRead)
        {
            return prop.GetValue(target, null);
        }

        return null;
    }

    private string ReadString(object target, string member, string fallback)
    {
        object value = GetMember(target, member);
        return value != null ? value.ToString() : fallback;
    }

    private float ReadFloat(object target, string member, float fallback)
    {
        object value = GetMember(target, member);

        if (value is float)
        {
            return (float)value;
        }

        if (value is int)
        {
            return (int)value;
        }

        if (value is double)
        {
            return (float)(double)value;
        }

        return fallback;
    }

    private bool ReadBool(object target, string member, bool fallback)
    {
        object value = GetMember(target, member);

        if (value is bool)
        {
            return (bool)value;
        }

        return fallback;
    }

    private Transform ReadTransform(object target, string member)
    {
        return GetMember(target, member) as Transform;
    }

    private MonoBehaviour FindBehaviourByTypeName(string typeName)
    {
        MonoBehaviour[] behaviours = Resources.FindObjectsOfTypeAll<MonoBehaviour>();

        for (int i = 0; i < behaviours.Length; i++)
        {
            MonoBehaviour b = behaviours[i];

            if (b == null || b.gameObject == null || !b.gameObject.scene.IsValid())
            {
                continue;
            }

            if (b.GetType().Name == typeName)
            {
                return b;
            }
        }

        return null;
    }

    private Font ResolveRuntimeFont()
    {
        Font f = null;

        try
        {
            f = Resources.GetBuiltinResource<Font>("LegacyRuntime.ttf");
        }
        catch
        {
            f = null;
        }

        if (f != null)
        {
            return f;
        }

        try
        {
            f = Font.CreateDynamicFontFromOSFont("Arial", 14);
        }
        catch
        {
            f = null;
        }

        return f;
    }

    private void ClearOldRoot()
    {
        if (dashboardCanvas == null)
