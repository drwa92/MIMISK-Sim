        contentRt.anchorMin = new Vector2(0, 1);
        contentRt.anchorMax = new Vector2(1, 1);
        contentRt.pivot = new Vector2(0, 1);

        GameObject item = CreatePanel("Item", content.transform, 0, 0, w, 26, panel2);
        Toggle toggle = item.AddComponent<Toggle>();

        Text itemLabel = CreateText("Item Label", item.transform, 10, 0, w - 20, 26, "Option", 12, FontStyle.Normal, white, TextAnchor.MiddleLeft);
        itemLabel.raycastTarget = false;

        toggle.targetGraphic = item.GetComponent<Image>();
        toggle.graphic = item.GetComponent<Image>();

        dropdown.targetGraphic = root.GetComponent<Image>();
        dropdown.captionText = caption;
        dropdown.template = template.GetComponent<RectTransform>();
        dropdown.itemText = itemLabel;

        scroll.viewport = viewport.GetComponent<RectTransform>();
        scroll.content = contentRt;

        return dropdown;
    }
