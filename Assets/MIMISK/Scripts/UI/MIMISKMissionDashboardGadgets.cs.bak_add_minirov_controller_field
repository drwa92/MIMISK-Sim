    private void Update()
    {
        if (!gadgetsEnabled)
        {
            if (rootRect != null)
            {
                rootRect.gameObject.SetActive(false);
            }

            return;
        }

        if (rootRect != null && !rootRect.gameObject.activeSelf)
        {
            rootRect.gameObject.SetActive(true);
        }

        if (autoFindPeriodically)
        {
            autoFindTimerS += Time.unscaledDeltaTime;

            if (autoFindTimerS >= autoFindPeriodS)
            {
                autoFindTimerS = 0.0f;
                AutoFindReferences();
            }
        }

        UpdateGauges();
        UpdatePhaseTimeline();
        UpdateTopDownMap();
        UpdateSelectorStatus();
    }

    [ContextMenu("Auto Find References")]
    public void AutoFindReferences()
    {
        if (dashboard == null) dashboard = FindBehaviourByTypeName("MIMISKMissionControlDashboard");

        if (droneTrajectoryPlanner == null) droneTrajectoryPlanner = FindBehaviourByTypeName("MIMISKDroneCoreTrajectoryPlanner");
        if (droneMissionManager == null) droneMissionManager = FindBehaviourByTypeName("MIMISKDroneCoreMissionManager");
        if (droneFlightManager == null) droneFlightManager = FindBehaviourByTypeName("MIMISKDroneCoreFlightModeManager");
        if (droneAgent == null) droneAgent = FindBehaviourByTypeName("MIMISKDroneAgent");

        if (miniRovPathPlanner == null) miniRovPathPlanner = FindBehaviourByTypeName("MIMISKMiniROVPathPlanner");
        if (miniRovMissionManager == null) miniRovMissionManager = FindBehaviourByTypeName("MIMISKMiniROVMissionManager");
        if (miniRovAgent == null) miniRovAgent = FindBehaviourByTypeName("MIMISKMiniROVAgent");

        if (unifiedTether == null) unifiedTether = FindBehaviourByTypeName("MIMISKUnifiedTetherManager");
        if (lowLevelTether == null) lowLevelTether = FindBehaviourByTypeName("MIMISKDroneCoreTetherManager");
        if (smartWinch == null) smartWinch = FindBehaviourByTypeName("MIMISKTetherSmartWinchController");

        if (droneRoot == null)
        {
            GameObject drone = GameObject.Find("Drone");

            if (drone != null)
            {
                droneRoot = drone.transform;
            }
        }

        if (droneTrajectoryPlanner == null && droneMissionManager != null)
        {
            droneTrajectoryPlanner =
                GetMember(droneMissionManager, "trajectoryPlanner") as MonoBehaviour;
        }

        if (miniRovPathPlanner == null && miniRovMissionManager != null)
        {
            miniRovPathPlanner =
                GetMember(miniRovMissionManager, "pathPlanner") as MonoBehaviour;
        }

        if (miniRovRoot == null)
        {
            Transform t = ReadTransform(unifiedTether, "miniRovRoot");

            if (t != null)
            {
                miniRovRoot = t;
            }
            else
            {
                GameObject rov = GameObject.Find("MiniROV");

                if (rov != null)
                {
                    miniRovRoot = rov.transform;
                }
            }
        }

        if (dashboardCanvas == null)
        {
            MIMISKMissionControlDashboard d =
                dashboard as MIMISKMissionControlDashboard;

            if (d != null)
            {
                dashboardCanvas = d.canvas;
            }
        }

        if (dashboardCanvas == null)
        {
            dashboardCanvas = FindObjectOfType<Canvas>();
        }
    }

    [ContextMenu("Build Gadgets")]
    public void BuildGadgets()
    {
        AutoFindReferences();

        if (dashboardCanvas == null)
        {
            Debug.LogError("[MIMISK] Dashboard gadgets need a Canvas. Run Setup Mission Control Dashboard first.");
            return;
        }

        if (uiFont == null)
        {
            uiFont = ResolveRuntimeFont();
        }

        ClearOldRoot();

        GameObject root = new GameObject("MIMISK_Dashboard_Gadgets");
        root.transform.SetParent(dashboardCanvas.transform, false);

        rootRect = root.AddComponent<RectTransform>();
        rootRect.anchorMin = new Vector2(0.5f, 0.5f);
        rootRect.anchorMax = new Vector2(0.5f, 0.5f);
        rootRect.pivot = new Vector2(0.5f, 0.5f);
        rootRect.anchoredPosition = Vector2.zero;
        rootRect.sizeDelta = new Vector2(1920, 1080);
        rootRect.localScale = Vector3.one;

        gauges.Clear();
        phaseNodes.Clear();

        if (coverOldBottomTelemetry)
        {
            CreatePanel("BottomGadgetBackdrop", rootRect, 290, 715, 880, 285, new Color(0.0f, 0.045f, 0.055f, 0.92f));
        }

        if (coverOldCameraGap)
        {
            CreatePanel("SelectorBackdrop", rootRect, 1180, 380, 350, 320, new Color(0.0f, 0.045f, 0.060f, 0.90f));
        }

        BuildPhaseTimeline(rootRect);
        BuildSelectorPanel(rootRect);
        BuildGaugePanel(rootRect);
        BuildTopDownMapPanel(rootRect);

        PopulateDropdowns();

        lastUiEvent = "dashboard_gadgets_built";
    }

    private void BuildPhaseTimeline(Transform parent)
    {
        CreatePanel("PhaseTimelinePanel", parent, 300, 92, 850, 58, new Color(0.0f, 0.035f, 0.050f, 0.70f));
        CreateText("PhaseTitle", parent, 315, 100, 120, 18, "MISSION PHASE", 13, FontStyle.Bold, white, TextAnchor.MiddleLeft);

        string[] phases =
        {
            "Surface",
            "Deploy",
            "ROV Ctrl",
            "Mission",
            "Return",
            "Recover"
        };

        float startX = 445.0f;
        float y = 104.0f;
        float step = 115.0f;

        for (int i = 0; i < phases.Length; i++)
        {
            PhaseNode node = new PhaseNode();
            node.name = phases[i];

            GameObject dot = CreatePanel("PhaseDot_" + phases[i], parent, startX + i * step, y, 18, 18, muted);
            node.dot = dot.GetComponent<Image>();

            node.label = CreateText(
                "PhaseLabel_" + phases[i],
                parent,
                startX + i * step - 35,
                y + 22,
                90,
                18,
                phases[i],
                11,
                FontStyle.Bold,
                white,
                TextAnchor.MiddleCenter
            );

            phaseNodes.Add(node);

            if (i < phases.Length - 1)
            {
                CreatePanel("PhaseLine_" + i, parent, startX + i * step + 18, y + 7, step - 18, 4, new Color(0.40f, 0.70f, 0.80f, 0.55f));
            }
        }
    }

