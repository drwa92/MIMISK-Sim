        template.SetActive(false);

        ScrollRect scroll = template.AddComponent<ScrollRect>();
        scroll.horizontal = false;

        GameObject viewport = CreatePanel("Viewport", template.transform, 0, 0, w, 180, new Color(0, 0, 0, 0));
