using System;
using System.Collections.Generic;
using System.Reflection;
using UnityEngine;
using UnityEngine.UI;

[DisallowMultipleComponent]
public class MIMISKDashboardTrajectoryMap : MaskableGraphic
{
    [Header("References")]
    public Transform droneRoot;
    public Transform miniRovRoot;
    public MonoBehaviour lowLevelTether;
    public MonoBehaviour miniRovController;

    [Header("Map")]
    public bool mapEnabled = true;
    public bool autoCenter = true;
    public float mapRangeM = 8.0f;
    public float samplePeriodS = 0.15f;
    public float minSampleDistanceM = 0.03f;
    public int maxTrailSamples = 600;

    [Header("Visuals")]
    public Color backgroundColor = new Color(0.0f, 0.045f, 0.055f, 0.96f);
    public Color gridColor = new Color(0.16f, 0.38f, 0.42f, 0.45f);
    public Color droneTrailColor = new Color(0.20f, 1.0f, 0.25f, 1.0f);
    public Color rovTrailColor = new Color(1.0f, 0.82f, 0.05f, 1.0f);
    public Color rovPlannedPathColor = new Color(0.1f, 0.45f, 1.0f, 0.75f);
    public Color tetherColor = new Color(1.0f, 0.70f, 0.05f, 0.95f);
    public Color droneMarkerColor = new Color(0.1f, 1.0f, 0.35f, 1.0f);
    public Color rovMarkerColor = new Color(1.0f, 0.85f, 0.05f, 1.0f);

    public float gridSpacingM = 1.0f;
    public float trailWidthPx = 3.0f;
    public float plannedPathWidthPx = 2.0f;
    public float tetherWidthPx = 2.0f;
    public float markerRadiusPx = 6.0f;

    [Header("Runtime")]
    public Vector3 mapCenterWorld;
    public int droneTrailCount;
    public int rovTrailCount;
    public string mapStatus = "idle";

    private readonly List<Vector3> droneTrail = new List<Vector3>();
    private readonly List<Vector3> rovTrail = new List<Vector3>();

    private float sampleTimerS;

    protected override void Awake()
    {
        base.Awake();
        raycastTarget = false;
    }

    private void Update()
    {
        if (!mapEnabled)
        {
            return;
        }

        sampleTimerS += Time.unscaledDeltaTime;

        if (sampleTimerS >= samplePeriodS)
        {
            sampleTimerS = 0.0f;
            SampleTrails();
        }

        SetVerticesDirty();
    }

    [ContextMenu("Clear Trails")]
    public void ClearTrails()
    {
        droneTrail.Clear();
        rovTrail.Clear();
        droneTrailCount = 0;
        rovTrailCount = 0;
        SetVerticesDirty();
    }

    public void SetReferences(
        Transform drone,
        Transform rov,
        MonoBehaviour tether,
        MonoBehaviour rovController)
    {
        droneRoot = drone;
        miniRovRoot = rov;
        lowLevelTether = tether;
        miniRovController = rovController;
    }

    private void SampleTrails()
    {
        if (droneRoot != null)
        {
            AddTrailSample(droneTrail, droneRoot.position);
        }

        if (miniRovRoot != null)
        {
            AddTrailSample(rovTrail, miniRovRoot.position);
        }

        droneTrailCount = droneTrail.Count;
        rovTrailCount = rovTrail.Count;
    }

    private void AddTrailSample(List<Vector3> trail, Vector3 p)
    {
        if (trail.Count > 0)
        {
            float d =
                Vector3.Distance(
                    trail[trail.Count - 1],
                    p
                );

            if (d < minSampleDistanceM)
            {
                return;
            }
        }

        trail.Add(p);

        while (trail.Count > maxTrailSamples)
        {
            trail.RemoveAt(0);
        }
    }

    protected override void OnPopulateMesh(VertexHelper vh)
    {
        vh.Clear();

        if (!mapEnabled)
        {
            return;
        }

        Rect r =
            GetPixelAdjustedRect();

        AddRect(vh, r, backgroundColor);

        UpdateMapCenter();
        DrawGrid(vh, r);

        DrawPlannedRovPath(vh, r);

        DrawWorldPolyline(vh, r, droneTrail, droneTrailColor, trailWidthPx);
        DrawWorldPolyline(vh, r, rovTrail, rovTrailColor, trailWidthPx);

        DrawTetherProjection(vh, r);

        if (droneRoot != null)
        {
            DrawCircle(
                vh,
                WorldToMapLocal(r, droneRoot.position),
                markerRadiusPx,
                droneMarkerColor
            );
        }

        if (miniRovRoot != null)
        {
            DrawCircle(
                vh,
                WorldToMapLocal(r, miniRovRoot.position),
                markerRadiusPx,
                rovMarkerColor
            );
        }

        mapStatus =
            "drone_trail=" + droneTrail.Count +
            ", rov_trail=" + rovTrail.Count;
    }

    private void UpdateMapCenter()
    {
        if (!autoCenter)
        {
            return;
        }

        bool hasDrone =
            droneRoot != null;

        bool hasRov =
            miniRovRoot != null;

        if (hasDrone && hasRov)
        {
            mapCenterWorld =
                0.5f * (droneRoot.position + miniRovRoot.position);
        }
        else if (hasDrone)
        {
            mapCenterWorld =
                droneRoot.position;
        }
        else if (hasRov)
        {
            mapCenterWorld =
                miniRovRoot.position;
        }
    }

    private void DrawGrid(VertexHelper vh, Rect r)
    {
        float pxPerM =
            PixelsPerMeter(r);

        if (pxPerM <= 0.001f)
        {
            return;
        }

        int count =
            Mathf.CeilToInt(mapRangeM / Mathf.Max(0.1f, gridSpacingM));

        for (int i = -count; i <= count; i++)
        {
            float offset =
                i * gridSpacingM * pxPerM;

            Vector2 a =
                new Vector2(r.center.x + offset, r.yMin);

            Vector2 b =
                new Vector2(r.center.x + offset, r.yMax);

            AddLine(vh, a, b, 1.0f, gridColor);

            a =
                new Vector2(r.xMin, r.center.y + offset);

            b =
                new Vector2(r.xMax, r.center.y + offset);

            AddLine(vh, a, b, 1.0f, gridColor);
        }
    }

    private void DrawPlannedRovPath(VertexHelper vh, Rect r)
    {
        Vector3[] path =
            GetVector3Array(miniRovController, "pathPointsWorld");

        if (path == null || path.Length < 2)
        {
            return;
        }

        List<Vector3> pathList =
            new List<Vector3>(path);

        DrawWorldPolyline(
            vh,
            r,
            pathList,
            rovPlannedPathColor,
            plannedPathWidthPx
        );
    }

    private void DrawTetherProjection(VertexHelper vh, Rect r)
    {
        Vector3 start =
            ReadVector3(lowLevelTether, "tetherStartWorld", Vector3.zero);

        Vector3 end =
            ReadVector3(lowLevelTether, "tetherEndWorld", Vector3.zero);

        if (start == Vector3.zero && end == Vector3.zero)
        {
            return;
        }

        AddLine(
            vh,
            WorldToMapLocal(r, start),
            WorldToMapLocal(r, end),
            tetherWidthPx,
            tetherColor
        );
    }

    private void DrawWorldPolyline(
        VertexHelper vh,
        Rect r,
        List<Vector3> points,
        Color c,
        float width)
    {
        if (points == null || points.Count < 2)
        {
            return;
        }

        for (int i = 1; i < points.Count; i++)
        {
            Vector2 a =
                WorldToMapLocal(r, points[i - 1]);

            Vector2 b =
                WorldToMapLocal(r, points[i]);

            AddLine(vh, a, b, width, c);
        }
    }

    private Vector2 WorldToMapLocal(Rect r, Vector3 p)
    {
        float pxPerM =
            PixelsPerMeter(r);

        float dx =
            p.x - mapCenterWorld.x;

        float dz =
            p.z - mapCenterWorld.z;

        return
            new Vector2(
                r.center.x + dx * pxPerM,
                r.center.y + dz * pxPerM
            );
    }

    private float PixelsPerMeter(Rect r)
    {
        return
            Mathf.Min(r.width, r.height) /
            Mathf.Max(0.1f, 2.0f * mapRangeM);
    }

    private void AddRect(VertexHelper vh, Rect r, Color colorValue)
    {
        int idx =
            vh.currentVertCount;

        UIVertex v =
            UIVertex.simpleVert;

        v.color = colorValue;

        v.position = new Vector3(r.xMin, r.yMin);
        vh.AddVert(v);

        v.position = new Vector3(r.xMin, r.yMax);
        vh.AddVert(v);

        v.position = new Vector3(r.xMax, r.yMax);
        vh.AddVert(v);

        v.position = new Vector3(r.xMax, r.yMin);
        vh.AddVert(v);

        vh.AddTriangle(idx, idx + 1, idx + 2);
        vh.AddTriangle(idx, idx + 2, idx + 3);
    }

    private void AddLine(
        VertexHelper vh,
        Vector2 a,
        Vector2 b,
        float width,
        Color colorValue)
    {
        Vector2 d =
            b - a;

        if (d.sqrMagnitude < 0.001f)
        {
            return;
        }

        Vector2 n =
            new Vector2(-d.y, d.x).normalized *
            width *
            0.5f;

        int idx =
            vh.currentVertCount;

        UIVertex v =
            UIVertex.simpleVert;

        v.color = colorValue;

        v.position = a + n;
        vh.AddVert(v);

        v.position = a - n;
        vh.AddVert(v);

        v.position = b - n;
        vh.AddVert(v);

        v.position = b + n;
        vh.AddVert(v);

        vh.AddTriangle(idx, idx + 1, idx + 2);
        vh.AddTriangle(idx, idx + 2, idx + 3);
    }

    private void DrawCircle(
        VertexHelper vh,
        Vector2 center,
        float radius,
        Color colorValue)
    {
        int segments =
            18;

        int start =
            vh.currentVertCount;

        UIVertex v =
            UIVertex.simpleVert;

        v.color = colorValue;
        v.position = center;
        vh.AddVert(v);

        for (int i = 0; i <= segments; i++)
        {
            float a =
                2.0f * Mathf.PI * i / segments;

            v.position =
                center +
                new Vector2(
                    Mathf.Cos(a) * radius,
                    Mathf.Sin(a) * radius
                );

            vh.AddVert(v);
        }

        for (int i = 1; i <= segments; i++)
        {
            vh.AddTriangle(start, start + i, start + i + 1);
        }
    }

    private Vector3[] GetVector3Array(object target, string name)
    {
        object value =
            GetMember(target, name);

        return value as Vector3[];
    }

    private Vector3 ReadVector3(object target, string name, Vector3 fallback)
    {
        object value =
            GetMember(target, name);

        if (value is Vector3)
        {
            return (Vector3)value;
        }

        return fallback;
    }

    private object GetMember(object target, string name)
    {
        if (target == null || string.IsNullOrEmpty(name))
        {
            return null;
        }

        Type type =
            target.GetType();

        FieldInfo field =
            type.GetField(
                name,
                BindingFlags.Instance |
                BindingFlags.Public |
                BindingFlags.NonPublic
            );

        if (field != null)
        {
            return field.GetValue(target);
        }

        PropertyInfo prop =
            type.GetProperty(
                name,
                BindingFlags.Instance |
                BindingFlags.Public |
                BindingFlags.NonPublic
            );

        if (prop != null && prop.CanRead)
        {
            return prop.GetValue(target, null);
        }

        return null;
    }
}
