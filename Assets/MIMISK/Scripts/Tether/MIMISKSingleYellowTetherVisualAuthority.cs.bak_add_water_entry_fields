    [Range(0.0f, 0.5f)]
    public float surfaceEntryTowardRovFraction = 0.12f;

    [Tooltip("Small depth below the surface to avoid z-fighting with the water plane.")]
    public float waterEntryBelowSurfaceM = 0.02f;

    [Tooltip("Extra underwater sag gain. This makes the underwater part look like a cable, not a vertical cut line.")]
    public float underwaterSagGain = 0.28f;

    public float underwaterMaxSagM = 0.60f;

    [Tooltip("Extra underwater side curvature even when the ROV is close to the drone.")]
    public float underwaterMinimumSideCurveM = 0.12f;

