    public string yellowCableEndName = "real_mesh_short_yellow_deployment_cable_to_hook";
    public string hookVisualName = "small_dark_open_deployment_hook_for_miniROV";

    public string winchCableMaterialSource1 = "real_mesh_yellow_cable_layer_3_wrapped_on_integrated_winch";
    public string winchCableMaterialSource2 = "real_mesh_yellow_cable_layer_2_wrapped_on_integrated_winch";
    public string winchCableMaterialSource3 = "real_mesh_yellow_cable_layer_1_wrapped_on_integrated_winch";

    public Transform fairlead;
    public Transform yellowCableEnd;
    public Transform hookVisual;
    public Transform winchCableMaterialSource;

