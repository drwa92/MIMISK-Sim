    public bool hideDuplicateCableObjects
    {
        get { return deactivateDuplicateCableObjects; }
        set { deactivateDuplicateCableObjects = value; }
    }

    // Kept for backward compatibility. The final visual authority never hides the hook via this flag.
    public bool keepHookVisible = true;
    public bool hideOtherTetherLineRenderers = true;

    [Tooltip("Hide the static short yellow mesh renderer, but still use its transform as the cable endpoint.")]
