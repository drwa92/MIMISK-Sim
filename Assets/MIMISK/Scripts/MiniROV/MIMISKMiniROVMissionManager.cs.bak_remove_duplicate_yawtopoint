    public bool CanStartMission()
    {
        if (!missionManagerEnabled || !missionEnabled)
        {
            lastEvent = "can_start_false_manager_disabled";
            return false;
        }

        if (missionState == MiniROVMissionState.Fault)
        {
            lastEvent = "can_start_false_fault";
            return false;
        }

        if (missionState == MiniROVMissionState.ReturningHome)
        {
            lastEvent = "can_start_false_returning_home";
            return false;
        }

        return true;
    }

    public void StartGamepadManualTest()
    {
        EnableManualDirectMode();
        lastEvent = "running_gamepad_test_started";
    }

    public void RequestReturnToRecovery()
    {
        ReturnHome();
        lastEvent = "legacy_request_return_to_recovery";
