    private void Awake()
    {
        AutoFindReferences();
        RefreshMissionActiveFlag();
    }

    private void Update()
    {
        if (!missionManagerEnabled || !missionEnabled)
        {
            return;
        }

        AutoFindReferences();
        RefreshState();
    }

    [ContextMenu("Auto Find References")]
    public void AutoFindReferences()
    {
        if (miniRovRoot == null)
        {
            miniRovRoot = transform;
        }

        if (rb == null)
        {
            rb = GetComponent<Rigidbody>();
        }

        if (miniRovRigidbody == null)
        {
            miniRovRigidbody = rb != null ? rb : GetComponent<Rigidbody>();
        }

        if (pathPlanner == null)
        {
            pathPlanner = GetComponent<MIMISKMiniROVPathPlanner>();
        }

        if (controller == null)
        {
            controller = GetComponent<MIMISKMiniROVPlantBasedController>();
        }

        if (directBypassInput == null)
        {
            directBypassInput = GetComponent<MIMISKMiniROVDirectRaspberryBypassInput>();
        }

        if (miniRovModule == null)
        {
            miniRovModule = GetComponent<MIMISKMiniROVModule>();
        }

        if (trajectoryPlanner == null)
        {
            trajectoryPlanner = GetComponent<MIMISKMiniROVTrajectoryPlanner>();
        }

        if (coreController == null)
        {
            coreController = GetComponent<MIMISKMiniROVCoreController>();
        }

        if (rovTetherAnchor == null && miniRovRoot != null)
        {
            rovTetherAnchor = FindDeepChild(miniRovRoot, "ROV_TetherAnchor");

            if (rovTetherAnchor == null)
            {
                rovTetherAnchor = FindDeepChild(miniRovRoot, "MiniROV_TetherPoint");
            }

            if (rovTetherAnchor == null)
            {
                rovTetherAnchor = FindDeepChild(miniRovRoot, "TetherPoint");
            }
        }
    }

    [ContextMenu("Set Home Here")]
    public void SetHomeHere()
    {
        AutoFindReferences();

        if (pathPlanner != null)
        {
            pathPlanner.SetHomeToCurrentPose();
        }

        lastEvent = "home_set";
    }

    [ContextMenu("Load Trajectory")]
    public void LoadTrajectory()
    {
        AutoFindReferences();

        InvokeIfExists(trajectoryPlanner, "LoadTrajectory");
        InvokeIfExists(pathPlanner, "BuildPath");

        lastEvent = "load_trajectory_requested_compat";
    }

    [ContextMenu("Start Selected Mission")]
    public void StartSelectedMission()
    {
        AutoFindReferences();

        if (!Application.isPlaying)
        {
            lastEvent = "start_selected_mission_rejected_not_playing";
            Debug.LogWarning("[MIMISK MiniROV MissionManager] Start Selected Mission must be used in Play Mode.");
            return;
        }

        if (!CanStartMission())
        {
            Debug.LogWarning("[MIMISK MiniROV MissionManager] Cannot start mission. Last event: " + lastEvent);
            return;
        }

        if (pathPlanner == null)
        {
            SetState(
                MiniROVMissionState.Fault,
                "start_failed_missing_path_planner"
            );

            Debug.LogError("[MIMISK MiniROV MissionManager] Missing path planner.");
            return;
        }

        if (usePathPlannerSelectedPath)
        {
            StartPlannerSelectedPath();
            return;
        }

        StartMissionAction(selectedMissionAction);
    }

    [ContextMenu("Hold Current Pose")]
    public void HoldCurrentPose()
    {
        AutoFindReferences();

        CancelDwellAction("hold_current_pose");

        CancelStopAndLookMission("hold_current_pose");

        CancelStopAndLookMission("hold_current_pose");

        if (directBypassInput != null)
        {
            directBypassInput.enabled = false;
            directBypassInput.receiverEnabled = false;
        }

        if (controller != null)
        {
            controller.StartHoldCurrentPose();
        }

        recoveryReady = false;

        SetState(
            MiniROVMissionState.StationHolding,
            "hold_current_pose"
        );
    }

