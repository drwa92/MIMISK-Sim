    public void StopMissionAndSetRecoveryReady()
    {
        AutoFindReferences();

        if (controller != null)
        {
            controller.StartHoldCurrentPose();
        }

        if (directBypassInput != null)
        {
            directBypassInput.receiverEnabled = false;
            directBypassInput.enabled = false;
        }

        recoveryReady = true;

        SetState(
            MiniROVMissionState.RecoveryReady,
            "legacy_stop_mission_recovery_ready"
        );
    }

    public void PrepareForRecovery()
    {
        StopMissionAndSetRecoveryReady();
    }

    public void StartMissionFromBridge(Vector3 recoveryPointWorld)
    {
        AutoFindReferences();

        if (pathPlanner != null)
        {
            pathPlanner.homeWorld = recoveryPointWorld;
            pathPlanner.homeDepthM =
                controller != null
                    ? controller.depthM
                    : pathPlanner.homeDepthM;

            pathPlanner.homeSet = true;
        }

        StartSelectedMission();

        lastEvent = "mission_started_from_bridge";
    }

