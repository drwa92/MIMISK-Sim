    private void Awake()
    {
        AutoFindReferences();
    }

    private void Start()
    {
        AutoFindReferences();

        Vector3 p;
        Vector3 v;
        float yaw;

        GetCurrentState(out p, out v, out yaw);

        referencePositionWorld = p;
        referenceVelocityWorld = Vector3.zero;
        referenceAccelerationWorld = Vector3.zero;
        referenceYawDeg = yaw;

        PushReferenceToCore();

        if (flightMode == FlightMode.Gamepad)
        {
            EnterGamepadMode();
        }
        else if (flightMode == FlightMode.TakeoffIdle)
        {
            EnterTakeoffIdle();
        }
        else if (flightMode == FlightMode.PositionHold)
        {
            CapturePositionHold();
        }
    }

    private void Update()
    {
        if (!managerEnabled)
        {
            return;
        }

        bool idlePressed = Keyboard.current != null && Keyboard.current[idleKey].wasPressedThisFrame;
        bool takeoffPressed = Keyboard.current != null && Keyboard.current[takeoffKey].wasPressedThisFrame;
        bool manualPressed = Keyboard.current != null && Keyboard.current[gamepadKey].wasPressedThisFrame;
        bool holdPressed = Keyboard.current != null && Keyboard.current[holdKey].wasPressedThisFrame;
        bool pathPressed = Keyboard.current != null && Keyboard.current[pathKey].wasPressedThisFrame;
        bool landPressed = Keyboard.current != null && Keyboard.current[landKey].wasPressedThisFrame;
        bool abortPressed = Keyboard.current != null && Keyboard.current[abortKey].wasPressedThisFrame;

        if (gamepad != null)
        {
            idlePressed |= gamepad.idleDown || gamepad.armDown;
            takeoffPressed |= gamepad.takeoffDown;
            manualPressed |= gamepad.manualDown;
            holdPressed |= gamepad.holdDown;
            pathPressed |= gamepad.pathDown;
            landPressed |= gamepad.landDown;
            abortPressed |= gamepad.abortDown;
        }

        if (idlePressed)
        {
            EnterTakeoffIdle();
        }

        if (takeoffPressed)
        {
            StartTakeoff();
        }

        if (manualPressed)
        {
            EnterGamepadMode();
        }

        if (holdPressed)
        {
            CapturePositionHold();
        }

        if (pathPressed)
        {
            StartPathTracking(pathKind);
        }

        if (landPressed)
        {
            StartLandingOnSurface();
        }

        if (gamepad != null && gamepad.disarmDown)
        {
            EnterDisarmed();
        }
        else if (abortPressed)
        {
            EnterFailsafe();
        }
    }

    private void FixedUpdate()
    {
        if (!managerEnabled || core == null)
        {
            return;
        }

        float dt = Time.fixedDeltaTime;
        modeTimerS += dt;

        if (flightMode == FlightMode.Disarmed ||
            flightMode == FlightMode.Disabled)
        {
            if (core != null)
            {
                core.controlMode = MIMISKDroneCoreRotorController.ControlMode.Disabled;
                core.CutMotors();
            }

            return;
        }

        if (flightMode == FlightMode.SurfaceStable ||
            flightMode == FlightMode.SurfaceHold)
        {
            referenceVelocityWorld = Vector3.zero;
            referenceAccelerationWorld = Vector3.zero;

            if (core != null)
            {
                core.controlMode = MIMISKDroneCoreRotorController.ControlMode.Disabled;
                core.CutMotors();
            }

            return;
        }

        if (flightMode == FlightMode.TakeoffIdle)
        {
            referenceVelocityWorld = Vector3.zero;
            referenceAccelerationWorld = Vector3.zero;
        }
        else if (flightMode == FlightMode.Takeoff)
        {
            UpdateTakeoff(dt);
        }
        else if (flightMode == FlightMode.Gamepad)
        {
            UpdateGamepadReference(dt);
        }
        else if (flightMode == FlightMode.PositionHold)
        {
            referenceVelocityWorld = Vector3.zero;
            referenceAccelerationWorld = Vector3.zero;
        }
        else if (flightMode == FlightMode.PathTracking)
        {
            UpdatePathTracking(dt);
        }
        else if (flightMode == FlightMode.PathBraking)
        {
            UpdatePathCompletionBrake(dt);
        }
        else if (flightMode == FlightMode.LandingOnSurface)
        {
            UpdateLandingOnSurface(dt);
        }
        else if (flightMode == FlightMode.SurfaceStable ||
                 flightMode == FlightMode.SurfaceHold)
        {
            referenceVelocityWorld = Vector3.zero;
            referenceAccelerationWorld = Vector3.zero;
        }

        PushReferenceToCore();
    }

    [ContextMenu("Auto Find References")]
    public void AutoFindReferences()
    {
        if (core == null)
        {
            core = GetComponent<MIMISKDroneCoreRotorController>();
        }

        if (gamepad == null)
        {
            gamepad = GetComponent<MIMISKDroneCoreGamepadReceiver>();
        }

        if (rb == null)
        {
            rb = GetComponent<Rigidbody>();
        }

        if (trajectoryPlanner == null)
        {
            trajectoryPlanner = GetComponent<MIMISKDroneCoreTrajectoryPlanner>();
        }

        if (surfaceBuoyancy == null)
        {
            surfaceBuoyancy = GetComponent<MIMISKDroneSurfaceBuoyancy>();
        }

        if (autoFindWaterContactSensors &&
            (waterContactSensors == null || waterContactSensors.Length == 0))
        {
            AutoFindWaterContactSensors();
        }
    }


