    public void StartPathTracking(PathKind kind)
    {
        Vector3 p;
        Vector3 v;
        float yaw;

        GetCurrentState(out p, out v, out yaw);

        flightMode = FlightMode.PathTracking;
        pathKind = kind;
        modeStartPositionWorld = p;
        modeStartYawDeg = yaw;
        modeTimerS = 0.0f;
        pathReferenceTimeS = 0.0f;
        pathRamp01 = 0.0f;

        referencePositionWorld = p;
        referenceVelocityWorld = Vector3.zero;
        referenceAccelerationWorld = Vector3.zero;
        referenceYawDeg = yaw;

        filteredManualVelocity = Vector3.zero;
        if (useTrajectoryPlanner && trajectoryPlanner != null)
        {
            trajectoryPlanner.Begin(modeStartPositionWorld, modeStartYawDeg);
        }

        lastModeEvent = "path_tracking_" + kind.ToString();
        PushReferenceToCore();
    }

    private void UpdateTakeoff(float dt)
    {
        float targetY =
            Mathf.Max(
                modeStartPositionWorld.y,
                waterSurfaceY + takeoffAltitudeAboveSurfaceM
            );

        if (useSmoothTakeoffReference)
        {
            float T = Mathf.Max(0.25f, takeoffSmoothDurationS);
            float q = Mathf.Clamp01(modeTimerS / T);

            float h = Smooth01(q);
            float dhdq = 6.0f * q * (1.0f - q);
            float d2hdq2 = 6.0f - 12.0f * q;

            float dy = targetY - modeStartPositionWorld.y;

            referencePositionWorld =
                modeStartPositionWorld +
                new Vector3(0.0f, dy * h, 0.0f);

            referenceVelocityWorld =
                new Vector3(0.0f, dy * dhdq / T, 0.0f);

            referenceAccelerationWorld =
                new Vector3(0.0f, dy * d2hdq2 / (T * T), 0.0f);

            referenceYawDeg = modeStartYawDeg;

            if (q >= 1.0f)
            {
                referencePositionWorld.y = targetY;
                referenceVelocityWorld = Vector3.zero;
                referenceAccelerationWorld = Vector3.zero;

                flightMode = FlightMode.PositionHold;
                modeTimerS = 0.0f;
                lastModeEvent = "takeoff_complete_position_hold";
            }

            return;
        }

        float oldY = referencePositionWorld.y;

        referencePositionWorld.y =
            Mathf.MoveTowards(
                referencePositionWorld.y,
                targetY,
                takeoffVerticalSpeedMS * dt
            );

        float vy =
            (referencePositionWorld.y - oldY) / Mathf.Max(0.001f, dt);

        referenceVelocityWorld =
            new Vector3(0.0f, vy, 0.0f);

        referenceAccelerationWorld = Vector3.zero;

        if (Mathf.Abs(referencePositionWorld.y - targetY) <= modeArrivalToleranceM)
        {
            CapturePositionHold();
            lastModeEvent = "takeoff_complete_position_hold";
        }
    }

    private void UpdateGamepadReference(float dt)
    {
        latestCommand =
            gamepad != null ? gamepad.commandForwardRightYawAlt : Vector4.zero;

        float forward = latestCommand.x;
        float right = latestCommand.y;
        float yaw = latestCommand.z;
        float altitude = latestCommand.w;

        Quaternion yawRotation =
            Quaternion.Euler(0.0f, referenceYawDeg, 0.0f);

        Vector3 bodyVelocityCommand =
            new Vector3(right, 0.0f, forward) * manualMaxHorizontalSpeedMS;

        Vector3 worldVelocityCommand =
            yawRotation * bodyVelocityCommand;

        Vector3 desiredVelocity =
            new Vector3(
                worldVelocityCommand.x,
                altitude * manualAltitudeRateMS,
                worldVelocityCommand.z
            );

        float alpha =
            1.0f - Mathf.Exp(-Mathf.Max(0.001f, manualReferenceResponseHz) * dt);

        filteredManualVelocity =
            Vector3.Lerp(filteredManualVelocity, desiredVelocity, alpha);

        referenceVelocityWorld = filteredManualVelocity;
        referencePositionWorld += referenceVelocityWorld * dt;
        referenceAccelerationWorld = Vector3.zero;

        referenceYawDeg += yaw * manualYawRateDegS * dt;

        while (referenceYawDeg >= 360.0f) referenceYawDeg -= 360.0f;
        while (referenceYawDeg < 0.0f) referenceYawDeg += 360.0f;
    }

    private void UpdatePathTracking(float dt)
    {
        if (useTrajectoryPlanner && trajectoryPlanner != null)
        {
            pathRamp01 =
                Smooth01(
                    Mathf.Clamp01(
                        pathRampTimeS <= 0.001f
                            ? 1.0f
                            : modeTimerS / pathRampTimeS
                    )
                );

            pathReferenceTimeS += pathRamp01 * dt;

            MIMISKDroneCoreTrajectoryPlanner.TrajectorySample sample =
                trajectoryPlanner.Evaluate(pathReferenceTimeS);

            referencePositionWorld = sample.positionWorld;
            referenceVelocityWorld = sample.velocityWorld * pathRamp01;
            referenceAccelerationWorld = sample.accelerationWorld * pathRamp01 * pathRamp01;
            referenceYawDeg = sample.yawDeg;

            if (sample.completed ||
                pathReferenceTimeS >= trajectoryPlanner.GetDuration())
            {
                if (enablePathCompletionBrake)
                {
                    StartPathCompletionBrake();
                }
                else
                {
                    CapturePositionHold();
                    lastModeEvent = "trajectory_complete_position_hold";
                }
            }

            return;
        }


        pathRamp01 =
            Smooth01(
                Mathf.Clamp01(
                    pathRampTimeS <= 0.001f
                        ? 1.0f
                        : modeTimerS / pathRampTimeS
                )
            );

        pathReferenceTimeS += pathRamp01 * dt;

        Vector3 p;
        Vector3 v;
        Vector3 a;

        EvaluatePathReference(
            pathReferenceTimeS,
            pathRamp01,
            out p,
            out v,
            out a
        );

        referencePositionWorld = p;
        referenceVelocityWorld = v;
        referenceAccelerationWorld = a;
        referenceYawDeg = modeStartYawDeg;

        if (pathReferenceTimeS >= GetPathDuration())
        {
            if (enablePathCompletionBrake)
            {
                StartPathCompletionBrake();
            }
            else
            {
                CapturePositionHold();
                lastModeEvent = "path_complete_position_hold";
            }
        }
    }


    public void StartPathCompletionBrake()
    {
        flightMode = FlightMode.PathBraking;
        modeTimerS = 0.0f;

        brakeStartPositionWorld = referencePositionWorld;
        brakeStartVelocityWorld = referenceVelocityWorld;
        brakeStartYawDeg = referenceYawDeg;

        float T = Mathf.Max(0.05f, pathCompletionBrakeSeconds);

        // Half-cosine braking: position advances by 0.5 * v0 * T,
        // velocity smoothly goes to zero, acceleration is continuous.
        brakeTargetPositionWorld =
            brakeStartPositionWorld +
            0.5f * brakeStartVelocityWorld * T;

        referenceAccelerationWorld = Vector3.zero;
        lastModeEvent = "path_completion_brake";
    }

    private void UpdatePathCompletionBrake(float dt)
    {
        float T = Mathf.Max(0.05f, pathCompletionBrakeSeconds);
        float q = Mathf.Clamp01(modeTimerS / T);

        float posScale =
            0.5f * q +
            Mathf.Sin(Mathf.PI * q) / (2.0f * Mathf.PI);

        float velScale =
            0.5f * (1.0f + Mathf.Cos(Mathf.PI * q));

        float accScale =
            -0.5f * Mathf.PI / T * Mathf.Sin(Mathf.PI * q);

        referencePositionWorld =
            brakeStartPositionWorld +
            brakeStartVelocityWorld * T * posScale;

        referenceVelocityWorld =
            brakeStartVelocityWorld * velScale;

        referenceAccelerationWorld =
            brakeStartVelocityWorld * accScale;

        referenceYawDeg = brakeStartYawDeg;

        if (q >= 1.0f)
        {
            flightMode = FlightMode.PositionHold;
            modeTimerS = 0.0f;

            referencePositionWorld = brakeTargetPositionWorld;
            referenceVelocityWorld = Vector3.zero;
            referenceAccelerationWorld = Vector3.zero;

            lastModeEvent = "path_brake_complete_position_hold";
        }
    }

    private void UpdateLandingOnSurface(float dt)
    {
        float targetY =
            waterSurfaceY + surfaceHoldHeightM;

        float oldY = referencePositionWorld.y;

        referencePositionWorld.y =
            Mathf.MoveTowards(
                referencePositionWorld.y,
                targetY,
                landingDescentSpeedMS * dt
            );

        float vy =
            (referencePositionWorld.y - oldY) / Mathf.Max(0.001f, dt);

        referenceVelocityWorld =
            new Vector3(0.0f, vy, 0.0f);

        referenceAccelerationWorld = Vector3.zero;

        bool lowEnough =
            GetCurrentAltitudeY() <= targetY + 0.15f;

        bool slowEnough =
            Mathf.Abs(GetVerticalSpeedMS()) <= landingTouchdownVerticalSpeedMS;

        bool contact =
            HasWaterContact();

        bool canEnterSurfaceStable =
            lowEnough &&
            slowEnough &&
            (!stopMotorsOnlyAfterWaterContact || contact);

        if (canEnterSurfaceStable)
        {
            EnterSurfaceStable();
        }
    }


    private void EnterSurfaceStable()
    {
        flightMode = FlightMode.SurfaceStable;
        modeTimerS = 0.0f;

        referencePositionWorld.y =
            waterSurfaceY + surfaceHoldHeightM;

        referenceVelocityWorld = Vector3.zero;
        referenceAccelerationWorld = Vector3.zero;

        filteredManualVelocity = Vector3.zero;
        lastModeEvent = "surface_stable";

        if (core != null)
        {
            core.controlMode =
                MIMISKDroneCoreRotorController.ControlMode.Disabled;

            core.CutMotors();
        }
    }

    private float GetCurrentAltitudeY()
    {
        if (core != null)
        {
            return core.estimatedPositionWorld.y;
        }

        if (rb != null)
        {
            return rb.position.y;
        }

        return transform.position.y;
    }

    private float GetVerticalSpeedMS()
    {
        if (core != null)
        {
            return core.estimatedVelocityWorld.y;
        }

        if (rb != null)
        {
            return rb.linearVelocity.y;
        }

        return 0.0f;
    }

    private bool HasWaterContact()
    {
        if (surfaceBuoyancy != null &&
            surfaceBuoyancy.activePointCount > 0)
        {
            return true;
        }

        if (waterContactSensors != null)
        {
            for (int i = 0; i < waterContactSensors.Length; i++)
            {
                Transform sensor = waterContactSensors[i];

                if (sensor == null)
                {
                    continue;
                }

                if (sensor.position.y <= waterSurfaceY + waterContactToleranceM)
                {
                    return true;
                }
            }
        }

        return false;
    }

    [ContextMenu("Auto Find Water Contact Sensors")]
    public void AutoFindWaterContactSensors()
    {
        string[] names =
        {
            "WaterContactSensor_FL",
            "WaterContactSensor_FR",
            "WaterContactSensor_RL",
            "WaterContactSensor_RR"
        };

        waterContactSensors = new Transform[names.Length];

        for (int i = 0; i < names.Length; i++)
        {
            waterContactSensors[i] = FindDeepChild(transform, names[i]);
        }
    }

    private Transform FindDeepChild(Transform root, string childName)
    {
        if (root == null)
        {
            return null;
        }

        if (root.name == childName)
        {
            return root;
        }

        for (int i = 0; i < root.childCount; i++)
        {
            Transform found = FindDeepChild(root.GetChild(i), childName);

            if (found != null)
            {
                return found;
            }
        }

        return null;
    }

    private void PushReferenceToCore()
    {
        if (core == null)
        {
            return;
        }

        if (flightMode == FlightMode.Disarmed ||
            flightMode == FlightMode.Disabled ||
            flightMode == FlightMode.SurfaceStable ||
            flightMode == FlightMode.SurfaceHold)
        {
            core.controlMode = MIMISKDroneCoreRotorController.ControlMode.Disabled;
            core.CutMotors();
            return;
        }

        core.controllerEnabled = true;
        core.acceptKeyboardShortcuts = false;
        core.controlMode = MIMISKDroneCoreRotorController.ControlMode.ExternalReference;

        core.SetExternalReference(
            referencePositionWorld,
            referenceVelocityWorld,
            referenceAccelerationWorld,
            referenceYawDeg
        );
    }

    private void GetCurrentState(out Vector3 p, out Vector3 v, out float yaw)
    {
        if (core != null)
        {
            p = core.estimatedPositionWorld;
            v = core.estimatedVelocityWorld;
            yaw = core.estimatedYawDeg;

            if (p.sqrMagnitude > 0.000001f)
            {
                return;
            }
        }

        if (rb != null)
        {
            p = rb.position;
            v = rb.linearVelocity;
            yaw = rb.rotation.eulerAngles.y;
            return;
        }

        p = transform.position;
        v = Vector3.zero;
        yaw = transform.eulerAngles.y;
    }

    private float GetPathDuration()
    {
        if (pathKind == PathKind.Square)
        {
            return 4.0f * squareSideM / Mathf.Max(0.05f, squareSpeedMS);
        }

        if (pathKind == PathKind.Spiral)
        {
            return Mathf.Max(missionDurationS, spiralDurationS);
        }

        return missionDurationS;
    }

    private void EvaluatePathReference(
        float t,
        float speedScale,
        out Vector3 p,
        out Vector3 v,
        out Vector3 a)
    {
        if (pathKind == PathKind.Circle)
        {
            float R = circleRadiusM;
            float w = circleOmegaRadS;
            float wt = w * t;

            p = modeStartPositionWorld + new Vector3(
                R * (Mathf.Cos(wt) - 1.0f),
                0.0f,
                R * Mathf.Sin(wt)
            );

            v = new Vector3(
                -R * w * Mathf.Sin(wt),
                0.0f,
                R * w * Mathf.Cos(wt)
            ) * speedScale;

            a = new Vector3(
                -R * w * w * Mathf.Cos(wt),
                0.0f,
                -R * w * w * Mathf.Sin(wt)
            ) * speedScale * speedScale;

            return;
        }

        if (pathKind == PathKind.Spiral)
        {
            float T = Mathf.Max(0.1f, spiralDurationS);
            float s = Mathf.Clamp01(t / T);
            float r = Mathf.Lerp(spiralInitialRadiusM, spiralFinalRadiusM, s);
            float rDot = t <= T ? (spiralFinalRadiusM - spiralInitialRadiusM) / T : 0.0f;
            float w = spiralOmegaRadS;
            float th = w * t;

            p = modeStartPositionWorld + new Vector3(
                r * Mathf.Cos(th) - spiralInitialRadiusM,
                spiralAltitudeRiseM * s,
                r * Mathf.Sin(th)
            );

            v = new Vector3(
                rDot * Mathf.Cos(th) - r * w * Mathf.Sin(th),
                spiralAltitudeRiseM / T,
                rDot * Mathf.Sin(th) + r * w * Mathf.Cos(th)
            ) * speedScale;

            a = new Vector3(
                -2.0f * rDot * w * Mathf.Sin(th) - r * w * w * Mathf.Cos(th),
                0.0f,
                2.0f * rDot * w * Mathf.Cos(th) - r * w * w * Mathf.Sin(th)
            ) * speedScale * speedScale;

            return;
        }

        EvaluateSquareReference(t, speedScale, out p, out v, out a);
    }

    private void EvaluateSquareReference(
        float t,
        float speedScale,
        out Vector3 p,
        out Vector3 v,
        out Vector3 a)
    {
        float side = Mathf.Max(0.1f, squareSideM);
        float speed = Mathf.Max(0.05f, squareSpeedMS);
        float segTime = side / speed;
        float totalTime = 4.0f * segTime;
        float tau = Mathf.Repeat(t, totalTime);

        Vector3 p0 = modeStartPositionWorld;
        Vector3 p1 = modeStartPositionWorld + new Vector3(side, 0.0f, 0.0f);
        Vector3 p2 = modeStartPositionWorld + new Vector3(side, 0.0f, side);
        Vector3 p3 = modeStartPositionWorld + new Vector3(0.0f, 0.0f, side);

        Vector3 a0;
        Vector3 b0;

        if (tau < segTime)
        {
            a0 = p0;
            b0 = p1;
        }
        else if (tau < 2.0f * segTime)
        {
            a0 = p1;
            b0 = p2;
            tau -= segTime;
        }
        else if (tau < 3.0f * segTime)
        {
            a0 = p2;
            b0 = p3;
            tau -= 2.0f * segTime;
        }
        else
        {
            a0 = p3;
            b0 = p0;
            tau -= 3.0f * segTime;
        }

        float u = Mathf.Clamp01(tau / segTime);

        p = Vector3.Lerp(a0, b0, u);
        v = (b0 - a0).normalized * speed * speedScale;
        a = Vector3.zero;
    }

    private float Smooth01(float x)
    {
        x = Mathf.Clamp01(x);
        return x * x * (3.0f - 2.0f * x);
    }
}
