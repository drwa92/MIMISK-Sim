    [System.Serializable]
    public class ScalarKalman1D
    {
        public bool initialized;
        public float x;
        public float p = 1.0f;

        public float Update(float z, float q, float r)
        {
            if (!initialized)
            {
                x = z;
                p = Mathf.Max(r, 1e-6f);
                initialized = true;
                return x;
            }

            p += Mathf.Max(q, 1e-9f);

            float s = p + Mathf.Max(r, 1e-9f);
            float k = p / s;

            x += k * (z - x);
            p = (1.0f - k) * p;

            return x;
        }

        public void Reset(float value, float covariance)
        {
            x = value;
            p = Mathf.Max(covariance, 1e-6f);
            initialized = true;
        }
    }

    [System.Serializable]
    public class AxisKalmanPV
    {
        public float position;
        public float velocity;

        public float p00 = 1.0f;
        public float p01 = 0.0f;
        public float p10 = 0.0f;
        public float p11 = 1.0f;

        public bool initialized;

        public void Reset(float pos, float vel, float posCov, float velCov)
        {
            position = pos;
            velocity = vel;

            p00 = Mathf.Max(posCov, 1e-6f);
            p11 = Mathf.Max(velCov, 1e-6f);
            p01 = 0.0f;
            p10 = 0.0f;

            initialized = true;
        }

        public void Predict(float acceleration, float dt, float qPosition, float qVelocity)
        {
            if (!initialized)
            {
                Reset(0.0f, 0.0f, 10.0f, 10.0f);
            }

            float dt2 = dt * dt;

            position = position + velocity * dt + 0.5f * acceleration * dt2;
            velocity = velocity + acceleration * dt;

            float np00 = p00 + dt * (p10 + p01) + dt2 * p11 + qPosition;
            float np01 = p01 + dt * p11;
            float np10 = p10 + dt * p11;
            float np11 = p11 + qVelocity;

            p00 = np00;
            p01 = np01;
            p10 = np10;
            p11 = np11;
        }

        public void UpdatePosition(float z, float r)
        {
            float s = p00 + Mathf.Max(r, 1e-9f);
            float k0 = p00 / s;
            float k1 = p10 / s;

            float y = z - position;

            position += k0 * y;
            velocity += k1 * y;

            float old00 = p00;
            float old01 = p01;

            p00 = (1.0f - k0) * old00;
            p01 = (1.0f - k0) * old01;
            p10 = p10 - k1 * old00;
            p11 = p11 - k1 * old01;
        }

        public void UpdateVelocity(float z, float r)
        {
            float s = p11 + Mathf.Max(r, 1e-9f);
            float k0 = p01 / s;
            float k1 = p11 / s;

            float y = z - velocity;

            position += k0 * y;
            velocity += k1 * y;

            float old10 = p10;
            float old11 = p11;

            p00 = p00 - k0 * old10;
            p01 = p01 - k0 * old11;
            p10 = (1.0f - k1) * old10;
            p11 = (1.0f - k1) * old11;
        }
    }

